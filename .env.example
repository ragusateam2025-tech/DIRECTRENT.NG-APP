# ─── Firebase Configuration ─────────────────────────────────────────────────
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=1:your_app_id
FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# ─── Paystack (Nigerian Payment Gateway) ─────────────────────────────────────
# Get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
# For testing:
# PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_test_public_key
# PAYSTACK_SECRET_KEY=sk_test_your_paystack_test_secret_key

# ─── VerifyMe API (BVN / NIN Identity Verification) ──────────────────────────
# Get these from https://verifyme.ng/developers
VERIFYME_API_KEY=your_verifyme_api_key
VERIFYME_API_SECRET=your_verifyme_api_secret
VERIFYME_BASE_URL=https://api.verifyme.ng/v1

# ─── Termii (Nigerian SMS Gateway) ───────────────────────────────────────────
# Get these from https://termii.com/account/api
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=Directrent

# ─── SendGrid (Transactional Email) ──────────────────────────────────────────
# Get this from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@directrent.ng
SENDGRID_FROM_NAME=Directrent

# ─── Google Maps Platform ─────────────────────────────────────────────────────
# Enable: Maps SDK for Android/iOS, Places API, Geocoding API
# Restrict key to your app bundle IDs in GCP console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── App Configuration ────────────────────────────────────────────────────────
APP_ENV=development
# Options: development | staging | production

# EAS Project IDs (from `eas init`)
EAS_PROJECT_ID_TENANT=your_tenant_eas_project_id
EAS_PROJECT_ID_LANDLORD=your_landlord_eas_project_id

# ─── Security (Cloud Functions) ──────────────────────────────────────────────
# HMAC secrets for BVN/NIN per-user hashing — minimum 32 characters
# Generate with: openssl rand -hex 32
BVN_HMAC_SECRET=your_32_char_minimum_bvn_hmac_secret_here
NIN_HMAC_SECRET=your_32_char_minimum_nin_hmac_secret_here
