rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isImage() { return request.resource.contentType.matches('image/.*'); }
    function isPdf() { return request.resource.contentType == 'application/pdf'; }
    function isUnder10MB() { return request.resource.size < 10 * 1024 * 1024; }
    function isUnder5MB() { return request.resource.size < 5 * 1024 * 1024; }

    // ── User profile photos — public read ─────────────────────────────────────

    match /users/{uid}/profile/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid) && isImage() && isUnder5MB();
    }

    // ── User verification documents — private ─────────────────────────────────

    match /users/{uid}/documents/{fileName} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && (isImage() || isPdf()) && isUnder10MB();
    }

    // ── Property photos — public read ─────────────────────────────────────────

    match /properties/{propertyId}/photos/{fileName} {
      allow read: if true;
      allow write: if isAuth() && isImage() && isUnder10MB();
    }

    // ── Property documents ────────────────────────────────────────────────────

    match /properties/{propertyId}/documents/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth() && (isImage() || isPdf()) && isUnder10MB();
    }

    // ── Chat attachments ──────────────────────────────────────────────────────

    match /conversations/{conversationId}/attachments/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth() && isUnder10MB();
    }

    // ── Lease documents — Cloud Functions only ────────────────────────────────

    match /leases/{leaseId}/{fileName} {
      allow read: if isAuth();
      allow write: if false;    // Cloud Functions only
    }
  }
}
